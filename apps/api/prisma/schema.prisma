// Prisma Schema for Qoomb
generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

// ============================================
// PUBLIC SCHEMA - Shared across all hives
// ============================================

model Hive {
  // name is stored encrypted by the service layer (AES-256-GCM, per-hive key).
  // TEXT instead of VarChar(255) because ciphertext is longer than plaintext.
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @db.Text
  type      String   @db.VarChar(50)
  // BCP 47 locale tag (e.g. 'de-DE', 'en-US'). NULL = inherit platform default.
  locale    String?  @db.VarChar(12)
  // Extensible hive configuration (JSON map of operator/user settings)
  settings  Json     @default("{}") @db.JsonB
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  memberships              UserHiveMembership[]
  persons                  Person[]
  hiveRolePermissions      HiveRolePermission[]
  hiveGroups               HiveGroup[]
  hiveGroupMembers         HiveGroupMember[]
  personShares             PersonShare[]
  groupShares              GroupShare[]
  events                   Event[]
  lists                    List[]
  invitations              Invitation[]
  notifications            Notification[]
  notificationPreferences  NotificationPreference[]
  directMessages           DirectMessage[]
  activityEvents           ActivityEvent[]

  @@map("hives")
}

model User {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  // emailHash: HMAC-SHA256 blind index for O(1) lookups (no plaintext stored).
  // email: AES-256-GCM ciphertext, per-user key — use enc.encryptForUser / decryptForUser.
  // fullName: AES-256-GCM ciphertext, per-user key — use enc.encryptForUser / decryptForUser.
  emailHash     String   @unique @map("email_hash") @db.VarChar(64)
  email         String   @db.Text
  passwordHash  String   @map("password_hash") @db.Text
  emailVerified Boolean  @default(false) @map("email_verified")
  isSystemAdmin Boolean  @default(false) @map("is_system_admin")
  fullName      String?  @map("full_name") @db.Text
  // locale: AES-256-GCM ciphertext, per-user key — use encryptUserLocale / decryptUserLocale.\n  // BCP 47 locale tag (e.g. 'de-DE', 'en-US'). NULL = inherit hive or platform default.
  locale        String?  @db.Text
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz

  refreshTokens           RefreshToken[]
  memberships             UserHiveMembership[]
  persons                 Person[]
  passKeyCredentials      PassKeyCredential[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  sentInvitations         Invitation[]             @relation("Inviter")

  @@map("users")
}

model UserHiveMembership {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  hiveId    String   @map("hive_id") @db.Uuid
  personId  String   @map("person_id") @db.Uuid
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  hive   Hive   @relation(fields: [hiveId], references: [id], onDelete: Cascade)
  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([userId, hiveId])
  @@index([userId])
  @@index([hiveId])
  @@index([personId])
  @@map("user_hive_memberships")
}

model RefreshToken {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  token           String    @unique @db.Text
  userId          String    @map("user_id") @db.Uuid
  expiresAt       DateTime  @map("expires_at") @db.Timestamptz
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  revokedAt       DateTime? @map("revoked_at") @db.Timestamptz
  replacedByToken String?   @map("replaced_by_token") @db.Text
  ipAddress       String?   @map("ip_address") @db.Inet
  userAgent       String?   @map("user_agent") @db.Text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@index([revokedAt])
  @@index([userId, token], name: "idx_refresh_tokens_active")
  @@map("refresh_tokens")
}

// ============================================
// HIVE-SCOPED TABLES (shared schema, isolated via RLS)
// Row-Level Security ensures each hive only sees its own rows.
// RLS policy: hive_id = current_setting('app.hive_id')::uuid
// ============================================

model Person {
  // displayName, avatarUrl, birthdate: AES-256-GCM ciphertext (hive-scoped key).
  // Stored as v{version}:{base64(IV+AuthTag+Ciphertext)} — see EncryptionService.
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hiveId      String   @map("hive_id") @db.Uuid
  userId      String?  @map("user_id") @db.Uuid
  role        String   @db.VarChar(50)
  displayName String?  @map("display_name") @db.Text
  avatarUrl   String?  @map("avatar_url") @db.Text
  birthdate   String?  @map("birthdate") @db.Text
  publicKey   String?  @map("public_key") @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  hive              Hive                 @relation(fields: [hiveId], references: [id], onDelete: Cascade)
  user              User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  memberships       UserHiveMembership[]
  personShares      PersonShare[]
  groupMemberships  HiveGroupMember[]    @relation("GroupMember")
  groupMembersAdded HiveGroupMember[]    @relation("GroupMemberAddedBy")
  createdEvents     Event[]
  createdLists     List[]     @relation("ListCreator")
  createdListItems ListItem[] @relation("ListItemCreator")
  notifications            Notification[]
  notificationPreferences  NotificationPreference[]
  sentMessages             DirectMessage[]        @relation("MessageSender")
  receivedMessages         DirectMessage[]        @relation("MessageRecipient")
  activityEvents           ActivityEvent[]
  listFavorites    ListFavorite[]

  @@index([hiveId])
  @@index([userId])
  @@map("persons")
}

// ============================================
// GROUPS
// ============================================

model HiveGroup {
  // name, description: AES-256-GCM ciphertext (hive-scoped key).
  // Stored as v{version}:{base64(IV+AuthTag+Ciphertext)} — see EncryptionService.
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hiveId      String   @map("hive_id") @db.Uuid
  name        String   @db.Text
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  hive        Hive              @relation(fields: [hiveId], references: [id], onDelete: Cascade)
  members     HiveGroupMember[]
  groupShares GroupShare[]
  events      Event[]
  lists       List[]

  @@index([hiveId])
  @@map("hive_groups")
}

model HiveGroupMember {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hiveId          String   @map("hive_id") @db.Uuid
  groupId         String   @map("group_id") @db.Uuid
  personId        String   @map("person_id") @db.Uuid
  addedByPersonId String?  @map("added_by_person_id") @db.Uuid
  joinedAt        DateTime @default(now()) @map("joined_at") @db.Timestamptz

  hive    Hive      @relation(fields: [hiveId], references: [id], onDelete: Cascade)
  group   HiveGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  person  Person    @relation("GroupMember", fields: [personId], references: [id], onDelete: Cascade)
  addedBy Person?   @relation("GroupMemberAddedBy", fields: [addedByPersonId], references: [id], onDelete: SetNull)

  @@unique([groupId, personId])
  @@index([hiveId])
  @@index([personId])
  @@map("hive_group_members")
}

// ============================================
// PERMISSION EXTENSION TABLES
// ============================================

model HiveRolePermission {
  // Per-hive override: grant or revoke a default role permission.
  // Allows admins to customize what each role can do in their specific hive.
  // Empty = use global HIVE_ROLE_PERMISSIONS defaults.
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hiveId     String  @map("hive_id") @db.Uuid
  role       String  @db.VarChar(50)
  permission String  @db.VarChar(100)
  granted    Boolean // true = grant above default, false = revoke from default

  hive Hive @relation(fields: [hiveId], references: [id], onDelete: Cascade)

  @@unique([hiveId, role, permission])
  @@index([hiveId])
  @@map("hive_role_permissions")
}

model PersonShare {
  // Explicit access grant for a specific person on a specific resource.
  // accessLevel: 1=VIEW, 2=EDIT, 3=MANAGE (hierarchical — higher implies lower)
  // resourceId is polymorphic (references events, tasks, etc.) — no FK.
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hiveId       String   @map("hive_id") @db.Uuid
  resourceType String   @map("resource_type") @db.VarChar(50)
  resourceId   String   @map("resource_id") @db.Uuid
  personId     String   @map("person_id") @db.Uuid
  accessLevel  Int      @map("access_level") @db.SmallInt
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  hive   Hive   @relation(fields: [hiveId], references: [id], onDelete: Cascade)
  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([resourceType, resourceId, personId])
  @@index([hiveId, resourceType, resourceId])
  @@map("person_shares")
}

model GroupShare {
  // Explicit access grant for an entire group on a specific resource.
  // All current and future members of the group inherit this access level.
  // accessLevel: 1=VIEW, 2=EDIT, 3=MANAGE (hierarchical — higher implies lower)
  // resourceId is polymorphic (references events, tasks, etc.) — no FK.
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hiveId       String   @map("hive_id") @db.Uuid
  resourceType String   @map("resource_type") @db.VarChar(50)
  resourceId   String   @map("resource_id") @db.Uuid
  groupId      String   @map("group_id") @db.Uuid
  accessLevel  Int      @map("access_level") @db.SmallInt
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  hive  Hive      @relation(fields: [hiveId], references: [id], onDelete: Cascade)
  group HiveGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([resourceType, resourceId, groupId])
  @@index([hiveId, resourceType, resourceId])
  @@map("group_shares")
}

// ============================================
// CONTENT TABLES (Phase 2)
// ============================================

model Event {
  // title, description, location, url, category are stored encrypted by the service layer.
  // recurrenceRule is unencrypted — needed for server-side occurrence expansion.
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hiveId         String   @map("hive_id") @db.Uuid
  creatorId      String   @map("creator_id") @db.Uuid
  groupId        String?  @map("group_id") @db.Uuid
  title          String   @db.Text
  description    String?  @db.Text
  startAt        DateTime @map("start_at") @db.Timestamptz
  endAt          DateTime @map("end_at") @db.Timestamptz
  allDay         Boolean  @default(false) @map("all_day")
  location       String?  @db.Text
  url            String?  @db.Text
  color          String?  @db.VarChar(20)
  category       String?  @db.Text
  visibility     String   @default("hive") @db.VarChar(20)
  recurrenceRule Json?    @map("recurrence_rule") @db.JsonB
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz

  hive    Hive       @relation(fields: [hiveId], references: [id], onDelete: Cascade)
  creator Person     @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  group   HiveGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)

  @@index([hiveId, startAt])
  @@index([hiveId, creatorId])
  @@index([hiveId, groupId])
  @@map("events")
}

// ============================================
// LISTS (see ADR-0007)
// ============================================

model List {
  // name: AES-256-GCM ciphertext when hiveId is set (hive-scoped key).
  // Global templates (hiveId IS NULL, isTemplate = true) store name as plaintext — see ADR-0009.
  //
  // type: 'custom' (default) | 'inbox'
  //   - 'inbox': the personal catch-all list auto-created per person on first access.
  //     Enforced UNIQUE by (hive_id, creator_id) WHERE type = 'inbox' partial index.
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hiveId     String?  @map("hive_id") @db.Uuid
  creatorId  String?  @map("creator_id") @db.Uuid
  groupId    String?  @map("group_id") @db.Uuid
  name       String   @db.Text
  icon       String?  @db.VarChar(50)
  type       String   @default("custom") @db.VarChar(20)
  systemKey  String?  @map("system_key") @db.VarChar(50)
  isTemplate Boolean  @default(false) @map("is_template")
  visibility String   @default("hive") @db.VarChar(20)
  sortOrder  Float    @default(0) @map("sort_order")
  isArchived Boolean  @default(false) @map("is_archived")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz

  hive    Hive?      @relation(fields: [hiveId], references: [id], onDelete: Cascade)
  creator Person?    @relation("ListCreator", fields: [creatorId], references: [id], onDelete: SetNull)
  group   HiveGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  fields  ListField[]
  views   ListView[]
  items   ListItem[]
  favorites ListFavorite[]

  @@unique([hiveId, creatorId, systemKey])
  @@index([hiveId])
  @@index([hiveId, creatorId])
  @@index([isTemplate])
  @@index([hiveId, type])
  @@map("lists")
}

model ListField {
  // name: AES-256-GCM ciphertext (hive-scoped key).
  // config: JSONB — SelectFieldConfig | ReferenceFieldConfig | NumberFieldConfig | {}
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  listId     String   @map("list_id") @db.Uuid
  name       String   @db.Text
  fieldType  String   @map("field_type") @db.VarChar(30)
  config     Json     @default("{}") @db.JsonB
  isRequired Boolean  @default(false) @map("is_required")
  isTitle    Boolean  @default(false) @map("is_title")
  sortOrder  Float    @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz

  list   List            @relation(fields: [listId], references: [id], onDelete: Cascade)
  values ListItemValue[]

  @@index([listId, sortOrder])
  @@map("list_fields")
}

model ListView {
  // name: AES-256-GCM ciphertext (hive-scoped key).
  // config, filter, sortBy: JSONB — view-type-specific structures.
  // sortMode: 'manual' = drag-and-drop order via sortOrder float;
  //           'auto'   = server-sorted by sortBy fields.
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  listId    String   @map("list_id") @db.Uuid
  name      String   @db.Text
  viewType  String   @map("view_type") @db.VarChar(20)
  sortMode  String   @default("manual") @map("sort_mode") @db.VarChar(10)
  config    Json     @default("{}") @db.JsonB
  filter    Json?    @db.JsonB
  sortBy    Json?    @map("sort_by") @db.JsonB
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  list List @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@index([listId])
  @@map("list_views")
}

model ListItem {
  // hiveId: denormalized from lists.hive_id for cheap RLS evaluation.
  // Kept in sync by the list_items_enforce_hive_id_trigger (BEFORE INSERT).
  // lists.hive_id is immutable, so no UPDATE trigger is needed.
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  listId         String   @map("list_id") @db.Uuid
  hiveId         String   @map("hive_id") @db.Uuid
  creatorId      String   @map("creator_id") @db.Uuid
  sortOrder      Float    @default(0) @map("sort_order")
  recurrenceRule Json?    @map("recurrence_rule") @db.JsonB
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz

  list    List            @relation(fields: [listId], references: [id], onDelete: Cascade)
  creator Person          @relation("ListItemCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  values  ListItemValue[]

  @@index([listId, sortOrder])
  @@index([hiveId])
  @@map("list_items")
}

model ListItemValue {
  // value: AES-256-GCM ciphertext (hive-scoped key). All field types are serialized
  // to string, encrypted, and stored in this single column. Filtering/sorting happens
  // client-side — the server never inspects decrypted values.
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  itemId    String   @map("item_id") @db.Uuid
  fieldId   String   @map("field_id") @db.Uuid
  value     String?  @map("value") @db.Text
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  item  ListItem  @relation(fields: [itemId], references: [id], onDelete: Cascade)
  field ListField @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([itemId, fieldId])
  @@index([fieldId])
  @@map("list_item_values")
}

// LIST TEMPLATES are now unified into the List model via isTemplate=true.
// See ADR-0009 for the rationale.

// ── ListFavorite ────────────────────────────────────────────────────────────
// Tracks which lists a person has starred, and in what order they want them.
// One row per (person, list) pair. sortOrder defines drag-and-drop position
// among a person's favorites. Scoped to hive via the list relation.
model ListFavorite {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  personId  String   @map("person_id") @db.Uuid
  listId    String   @map("list_id") @db.Uuid
  sortOrder Float    @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)
  list   List   @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@unique([personId, listId])
  @@index([personId])
  @@index([listId])
  @@map("list_favorites")
}

// ============================================
// AUTH EXTENSION TABLES
// ============================================

model PassKeyCredential {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId              String    @map("user_id") @db.Uuid
  credentialId        String    @unique @map("credential_id") @db.Text
  credentialPublicKey Bytes     @map("credential_public_key")
  counter             BigInt    @default(0)
  transports          String[]
  deviceName          String?   @map("device_name") @db.VarChar(255)
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz
  lastUsedAt          DateTime? @map("last_used_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("passkey_credentials")
}

model EmailVerificationToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  token     String    @unique @db.Text
  userId    String    @map("user_id") @db.Uuid
  expiresAt DateTime  @map("expires_at") @db.Timestamptz
  usedAt    DateTime? @map("used_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  token     String    @unique @db.Text
  userId    String    @map("user_id") @db.Uuid
  expiresAt DateTime  @map("expires_at") @db.Timestamptz
  usedAt    DateTime? @map("used_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model Invitation {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  // email: normalized plaintext email address (lowercase, trimmed).
  // Stored so that emailHash can be recomputed during key rotation without
  // losing pending invitations. Acceptable trade-off: invitations are
  // short-lived (7 days) and the email is already known to the inviter.
  // See ADR-0008 and migration 20260314000005_invitation_email.
  email           String    @db.Text
  // emailHash: HMAC-SHA256 blind index for O(1) lookup on registration.
  emailHash       String    @map("email_hash") @db.VarChar(64)
  token           String    @unique @db.Text
  invitedByUserId String    @map("invited_by_user_id") @db.Uuid
  hiveId          String?   @map("hive_id") @db.Uuid
  expiresAt       DateTime  @map("expires_at") @db.Timestamptz
  usedAt          DateTime? @map("used_at") @db.Timestamptz
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz

  invitedByUser User  @relation("Inviter", fields: [invitedByUserId], references: [id], onDelete: Cascade)
  hive          Hive? @relation(fields: [hiveId], references: [id], onDelete: SetNull)

  @@index([emailHash])
  @@index([invitedByUserId])
  @@index([expiresAt])
  @@map("invitations")
}

// ============================================
// PHASE 3: NOTIFICATIONS, MESSAGING, ACTIVITY
// ============================================

model Notification {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hiveId            String   @map("hive_id") @db.Uuid
  recipientPersonId String   @map("recipient_person_id") @db.Uuid
  // Enum-like type for client-side routing (not encrypted — structural metadata)
  notificationType  String   @map("notification_type") @db.VarChar(50)
  // AES-256-GCM ciphertext (hive-scoped key)
  title             String   @db.Text
  // AES-256-GCM ciphertext (hive-scoped key)
  body              String?  @db.Text
  resourceType      String?  @map("resource_type") @db.VarChar(50)
  resourceId        String?  @map("resource_id") @db.Uuid
  isRead            Boolean  @default(false) @map("is_read")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz

  hive      Hive   @relation(fields: [hiveId], references: [id], onDelete: Cascade)
  recipient Person @relation(fields: [recipientPersonId], references: [id], onDelete: Cascade)

  @@index([hiveId])
  @@index([hiveId, recipientPersonId, isRead], map: "idx_notifications_recipient")
  @@index([hiveId, recipientPersonId, createdAt(sort: Desc)], map: "idx_notifications_created")
  @@map("notifications")
}

model NotificationPreference {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hiveId      String   @map("hive_id") @db.Uuid
  personId    String   @map("person_id") @db.Uuid
  // JSON map: notificationType -> { inApp: bool, email: bool }
  preferences Json     @default("{}") @db.JsonB
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  hive   Hive   @relation(fields: [hiveId], references: [id], onDelete: Cascade)
  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([hiveId, personId], map: "uq_notification_preferences")
  @@index([hiveId], map: "idx_notification_preferences_hive")
  @@index([personId], map: "idx_notification_preferences_person")
  @@map("notification_preferences")
}

model DirectMessage {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hiveId            String   @map("hive_id") @db.Uuid
  senderPersonId    String   @map("sender_person_id") @db.Uuid
  recipientPersonId String   @map("recipient_person_id") @db.Uuid
  // AES-256-GCM ciphertext (hive-scoped key)
  body              String   @db.Text
  isRead            Boolean  @default(false) @map("is_read")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz

  hive      Hive   @relation(fields: [hiveId], references: [id], onDelete: Cascade)
  sender    Person @relation("MessageSender", fields: [senderPersonId], references: [id], onDelete: Cascade)
  recipient Person @relation("MessageRecipient", fields: [recipientPersonId], references: [id], onDelete: Cascade)

  @@index([hiveId], map: "idx_direct_messages_hive")
  @@index([hiveId, senderPersonId, recipientPersonId, createdAt(sort: Desc)], map: "idx_direct_messages_conversation")
  @@index([hiveId, recipientPersonId, isRead], map: "idx_direct_messages_inbox")
  @@map("direct_messages")
}

model ActivityEvent {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hiveId        String   @map("hive_id") @db.Uuid
  actorPersonId String?  @map("actor_person_id") @db.Uuid
  // Enum-like action type (not encrypted — structural metadata)
  action        String   @db.VarChar(50)
  resourceType  String   @map("resource_type") @db.VarChar(50)
  resourceId    String   @map("resource_id") @db.Uuid
  // AES-256-GCM ciphertext (hive-scoped key): human-readable summary
  summary       String?  @db.Text
  // Raw metadata snapshot (JSONB, unencrypted — no PII, structural only)
  metadata      Json     @default("{}") @db.JsonB
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  hive  Hive    @relation(fields: [hiveId], references: [id], onDelete: Cascade)
  actor Person? @relation(fields: [actorPersonId], references: [id], onDelete: SetNull)

  @@index([hiveId, createdAt(sort: Desc)], map: "idx_activity_events_hive")
  @@index([hiveId, resourceType, resourceId], map: "idx_activity_events_resource")
  @@index([hiveId, actorPersonId], map: "idx_activity_events_actor")
  @@map("activity_events")
}

// ============================================
// RE-ENCRYPTION AUDIT / BACKUP TABLE
// ============================================

/// Stores old ciphertexts before they are overwritten during key rotation.
/// Written atomically within the same DB transaction as the UPDATE that
/// replaces the ciphertext, so either both succeed or neither does.
///
/// Retention: rows expire after REENCRYPT_BACKUP_RETENTION_DAYS days (default 30).
/// Run `db:reencrypt-cleanup` to delete expired rows after confirmed stability.
model ReencryptBackup {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// Name of the table that was updated, e.g. "users" or "events".
  tableName      String   @map("table_name") @db.Text
  /// UUID of the affected row in that table.
  recordId       String   @map("record_id") @db.Uuid
  /// Column name that was re-encrypted, e.g. "email" or "title".
  fieldName      String   @map("field_name") @db.Text
  /// The verbatim ciphertext that was in the DB before the migration.
  oldCiphertext  String   @map("old_ciphertext") @db.Text
  /// Key version the old ciphertext was encrypted with.
  fromVersion    Int      @map("from_version")
  /// Key version the new ciphertext is encrypted with.
  toVersion      Int      @map("to_version")
  /// Timestamp of the migration run that produced this row.
  migratedAt     DateTime @default(now()) @map("migrated_at") @db.Timestamptz
  /// When this backup row may be deleted (migratedAt + REENCRYPT_BACKUP_RETENTION_DAYS).
  expiresAt      DateTime @map("expires_at") @db.Timestamptz

  @@index([expiresAt], name: "reencrypt_backups_expires_idx")
  @@index([tableName, recordId], name: "reencrypt_backups_record_idx")
  @@map("reencrypt_backups")
}
