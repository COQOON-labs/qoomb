echo "🔍 Running pre-push checks..."

# Generate Prisma client (required for type-check)
echo "🗄️  Generating Prisma client..."
pnpm run db:generate

# Lint all packages
echo "🔎 Linting..."
pnpm run lint

# Check formatting (catches files not touched by lint-staged)
echo "🎨 Checking formatting..."
pnpm run format:check

# Type check all packages
echo "📝 Type checking..."
pnpm turbo run type-check

# Run tests + enforce coverage thresholds (80% on tested modules)
echo "🧪 Running tests..."
pnpm turbo run test --filter='!@qoomb/web'

echo "📊 Checking coverage thresholds..."
pnpm --filter @qoomb/api test:cov --silent
pnpm --filter @qoomb/validators test:coverage --silent

# Build check (full build to catch Vite import resolution errors)
echo "🏗️  Build check..."
pnpm turbo run build

echo "✅ Pre-push checks passed!"
